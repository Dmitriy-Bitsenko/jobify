# Django
SECRET_KEY=<your-secret-key>
DEBUG=True

# HH.ru API (OAuth 2.0)
HH_CLIENT_ID=<your-client-id>
HH_CLIENT_SECRET=<your-client-secret>
HH_ACCESS_TOKEN=<your-access-token>

# Database (SQLite для разработки)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

